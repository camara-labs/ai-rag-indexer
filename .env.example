# ── OpenAI-compatible embedding server ────────────────────────────────────────
# URL base do servidor (LM Studio, Ollama, vLLM, llama.cpp, OpenAI real, etc.)
OPENAI_BASE_URL=http://localhost:1234/v1

# Chave de API — obrigatória pelo SDK mesmo para servidores locais (qualquer string serve)
OPENAI_API_KEY=not-needed

# ID do modelo de embedding carregado no servidor
# Descobrir modelos disponíveis: curl http://localhost:1234/v1/models
EMBED_MODEL=text-embedding-bge-m3

# ID do modelo de chat/LLM (usado pelo summarizer.py)
# Deve ser um modelo generativo, não de embedding
LLM_MODEL=qwen3-4b

# URL base do servidor de chat/LLM (pode ser diferente do servidor de embeddings)
# Se omitido, usa OPENAI_BASE_URL
LLM_BASE_URL=http://localhost:1234/v1

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# API key do Qdrant (opcional — necessário apenas se o Qdrant estiver configurado com autenticação)
# QDRANT_API_KEY=
